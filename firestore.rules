rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Products: Anyone can read, only authenticated admin/employees can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Orders: Customers can create, only authenticated admin/employees can read/update/delete
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 3. Settings: Anyone can read site settings, only admin can write
    match /settings/site {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'admin@spicemarket.com' || request.auth.token.email.matches('(?i)^admin@.*'));
    }

    // 4. Employees: Only admin can read/write employee records
    match /employees/{employeeId} {
      allow read, write: if request.auth != null && (request.auth.token.email == 'admin@spicemarket.com' || request.auth.token.email.matches('(?i)^admin@.*'));
    }
  }
}
